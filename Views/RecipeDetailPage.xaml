<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    x:Class="RecipeApp.Views.RecipeDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:RecipeApp.Models"
    xmlns:conv="clr-namespace:RecipeApp.Converters"
    Title="{Binding Title}">

    <ContentPage.Resources>
        <conv:NullToBoolConverter    x:Key="NullBool"/>
        <conv:MinutesToTimeConverter x:Key="MinTime"/>
        <conv:ImagePathConverter     x:Key="ImgPath"/>
        <conv:PositiveToBoolConverter x:Key="PosBool"/>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Изменить" Clicked="OnEditClicked"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero image -->
            <Image Source="{Binding ImagePath, Converter={StaticResource ImgPath}}"
                   Aspect="AspectFill"
                   HeightRequest="240"
                   IsVisible="{Binding ImagePath, Converter={StaticResource NullBool}}"/>

            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Title -->
                <Label Text="{Binding Title}"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"/>

                <!-- Meta chips -->
                <FlexLayout Wrap="Wrap" Direction="Row" Gap="8">
                    <Frame Style="{StaticResource Chip}">
                        <Label Text="{Binding Category}" FontSize="13"
                               TextColor="{StaticResource Primary}"/>
                    </Frame>
                    <Frame Style="{StaticResource Chip}"
                           IsVisible="{Binding TotalTimeMinutes, Converter={StaticResource PosBool}}">
                        <Label Text="{Binding TotalTimeMinutes, Converter={StaticResource MinTime}}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </Frame>
                    <Frame Style="{StaticResource Chip}"
                           IsVisible="{Binding Servings, Converter={StaticResource PosBool}}">
                        <Label Text="{Binding Servings, StringFormat='{0} порц.'}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </Frame>
                    <Frame Style="{StaticResource Chip}">
                        <Label Text="{Binding Difficulty}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                    </Frame>
                </FlexLayout>

                <!-- Description -->
                <Label Text="{Binding Description}"
                       Style="{StaticResource BodyLabel}"
                       IsVisible="{Binding Description, Converter={StaticResource NullBool}}"/>

                <!-- КБЖУ -->
                <Frame Style="{StaticResource Card}" Padding="12">
                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                        <!-- Калории -->
                        <Frame Grid.Column="0" BackgroundColor="{StaticResource CaloriesBg}"
                               BorderColor="Transparent" CornerRadius="8" Padding="8,6" HasShadow="False">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding TotalCalories, StringFormat='{0:0}'}"
                                       FontAttributes="Bold" FontSize="18"
                                       TextColor="{StaticResource CaloriesText}"
                                       HorizontalOptions="Center"/>
                                <Label Text="ккал" FontSize="11"
                                       TextColor="{StaticResource CaloriesText}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <!-- Белки -->
                        <Frame Grid.Column="1" BackgroundColor="{StaticResource ProteinBg}"
                               BorderColor="Transparent" CornerRadius="8" Padding="8,6" HasShadow="False">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding TotalProtein, StringFormat='{0:0.#} г'}"
                                       FontAttributes="Bold" FontSize="15"
                                       TextColor="{StaticResource ProteinText}"
                                       HorizontalOptions="Center"/>
                                <Label Text="белки" FontSize="11"
                                       TextColor="{StaticResource ProteinText}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <!-- Жиры -->
                        <Frame Grid.Column="2" BackgroundColor="{StaticResource FatBg}"
                               BorderColor="Transparent" CornerRadius="8" Padding="8,6" HasShadow="False">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding TotalFat, StringFormat='{0:0.#} г'}"
                                       FontAttributes="Bold" FontSize="15"
                                       TextColor="{StaticResource FatText}"
                                       HorizontalOptions="Center"/>
                                <Label Text="жиры" FontSize="11"
                                       TextColor="{StaticResource FatText}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <!-- Углеводы -->
                        <Frame Grid.Column="3" BackgroundColor="{StaticResource CarbsBg}"
                               BorderColor="Transparent" CornerRadius="8" Padding="8,6" HasShadow="False">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding TotalCarbs, StringFormat='{0:0.#} г'}"
                                       FontAttributes="Bold" FontSize="15"
                                       TextColor="{StaticResource CarbsText}"
                                       HorizontalOptions="Center"/>
                                <Label Text="углев." FontSize="11"
                                       TextColor="{StaticResource CarbsText}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Ingredients -->
                <Label Text="Ингредиенты" Style="{StaticResource SectionTitle}"/>
                <Frame Style="{StaticResource Card}" Padding="12">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Ingredients}" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Ingredient">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           Style="{StaticResource BodyLabel}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Amount}"
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="14"
                                           Margin="8,0"/>
                                    <Label Grid.Column="2"
                                           Text="{Binding Unit}"
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="14"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Frame>

                <!-- Steps -->
                <Label Text="Приготовление" Style="{StaticResource SectionTitle}"/>
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Steps}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Step">
                            <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{StaticResource Primary}"
                                       BorderColor="Transparent"
                                       CornerRadius="18"
                                       WidthRequest="36"
                                       HeightRequest="36"
                                       Padding="0"
                                       HasShadow="False"
                                       HorizontalOptions="Center">
                                    <Label Text="{Binding Order}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <Label Grid.Column="1"
                                       Text="{Binding Description}"
                                       Style="{StaticResource BodyLabel}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView Style="{StaticResource Separator}" HeightRequest="40" Opacity="0"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
