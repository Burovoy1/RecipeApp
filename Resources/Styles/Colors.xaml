<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand colors -->
    <Color x:Key="Primary">#E8623A</Color>
    <Color x:Key="PrimaryDark">#C4472A</Color>
    <Color x:Key="PrimaryLight">#FDEEE8</Color>
    <Color x:Key="Accent">#2ECC71</Color>

    <!-- Background -->
    <Color x:Key="Background">#F8F5F0</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceAlt">#FFF9F5</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#2C2C2C</Color>
    <Color x:Key="TextSecondary">#777777</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Border -->
    <Color x:Key="Border">#E8E0D8</Color>

    <!-- Semantic -->
    <Color x:Key="Danger">#E74C3C</Color>
    <Color x:Key="DangerLight">#FDEDEC</Color>
    <Color x:Key="Success">#27AE60</Color>
    <Color x:Key="SuccessLight">#EAFAF1</Color>
    <Color x:Key="Warning">#F39C12</Color>

    <!-- Nutrition badges -->
    <Color x:Key="CaloriesBg">#FFF3E0</Color>
    <Color x:Key="CaloriesText">#E65100</Color>
    <Color x:Key="ProteinBg">#E3F2FD</Color>
    <Color x:Key="ProteinText">#1565C0</Color>
    <Color x:Key="FatBg">#FFF8E1</Color>
    <Color x:Key="FatText">#F57F17</Color>
    <Color x:Key="CarbsBg">#E8F5E9</Color>
    <Color x:Key="CarbsText">#2E7D32</Color>

</ResourceDictionary>
