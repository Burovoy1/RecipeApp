<?xml version="1.0" encoding="utf-8"?>
<Shell
    x:Class="RecipeApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:RecipeApp.Views"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <Tab Title="Рецепты" Icon="icon_recipes.png">
            <ShellContent
                Route="recipes"
                ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

        <Tab Title="Продукты" Icon="icon_db.png">
            <ShellContent
                Route="fooddb"
                ContentTemplate="{DataTemplate views:FoodDatabasePage}" />
        </Tab>

        <Tab Title="Питание" Icon="icon_nutrition.png">
            <ShellContent
                Route="nutrition"
                ContentTemplate="{DataTemplate views:NutritionPage}" />
        </Tab>
    </TabBar>

</Shell>
